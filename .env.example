# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Change if you want to use a different expose port for the app in docker-compose
FORWARD_APP_PORT=3000

# ── PostgreSQL────────────────────────────────────────────────────────────────────
DB_HOST=nest-setup-app-db
DB_PORT=5432
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
# Change if you want to use a different expose port for the database in docker-compose
FORWARD_DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis host must be the hostname only. Do NOT append :port here.
REDIS_HOST=nest-setup-app-redis
REDIS_PORT=6379
# Change if you want to use a different expose port for the redis in docker-compose
FORWARD_REDIS_PORT=6379

# PostgreSQL connection used by the app container
DATABASE_URL=postgresql://db_user:db_password@nest-setup-app-db:5432/db_name?schema=public

# Optional test-only database URL used when NODE_ENV=test and DATABASE_URL is not provided
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Auth
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL=7d
